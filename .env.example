# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/prosync-hub
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=prosync-hub
MONGODB_AUTH_SOURCE=admin
MONGODB_REPLICA_SET=
MONGODB_MAX_POOL_SIZE=10
MONGODB_CONNECTION_TIMEOUT=30000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=false
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# Application Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Authentication Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
SESSION_SECRET=your-session-secret-change-in-production

# Caching Configuration
ASSET_CACHE_TTL=3600  # 1 hour in seconds
SENSOR_CACHE_TTL=300  # 5 minutes in seconds
USER_CACHE_TTL=1800   # 30 minutes in seconds
USER_SESSION_TTL=86400  # 24 hours in seconds

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000  # 1 minute in milliseconds

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000  # 30 seconds in milliseconds
WS_PATH=/ws
WS_MAX_PAYLOAD=100kb

# Security Configuration
COOKIE_SECURE=false  # Set to true in production
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax  # Set to strict in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
ENABLE_RATE_LIMITING=true

# Deployment Configuration
ENABLE_CLUSTER_MODE=false
WORKER_THREADS=0  # 0 means use number of CPU cores
