{
  "openapi": "3.0.0",
  "info": {
    "title": "ProSync Hub API",
    "version": "1.0.0",
    "description": "API documentation for ProSync Hub industrial asset management platform."
  },
  "servers": [
    { "url": "http://localhost:5000", "description": "Local server" }
  ],
  "paths": {
    "/api/assets": {
      "get": { "summary": "Get a list of assets", "tags": ["Assets"], "responses": { "200": { "description": "List of assets" } } },
      "post": { "summary": "Create a new asset", "tags": ["Assets"], "responses": { "201": { "description": "Asset created" } } }
    },
    "/api/assets/{id}": {
      "get": { "summary": "Get asset by ID", "tags": ["Assets"], "responses": { "200": { "description": "Asset details" }, "404": { "description": "Not found" } } },
      "put": { "summary": "Update asset", "tags": ["Assets"], "responses": { "200": { "description": "Asset updated" } } },
      "delete": { "summary": "Delete asset", "tags": ["Assets"], "responses": { "200": { "description": "Asset deleted" } } }
    },
    "/api/maintenance": {
      "get": { "summary": "Get maintenance schedules", "tags": ["Maintenance"], "responses": { "200": { "description": "List of schedules" } } },
      "post": { "summary": "Create maintenance schedule", "tags": ["Maintenance"], "responses": { "201": { "description": "Schedule created" } } }
    },
    "/api/notifications": {
      "get": { "summary": "Get notifications", "tags": ["Notifications"], "responses": { "200": { "description": "List of notifications" } } },
      "post": { "summary": "Create notification", "tags": ["Notifications"], "responses": { "201": { "description": "Notification created" } } }
    },
    "/api/mongo/sensor-data": {
      "get": { "summary": "Get sensor data with filtering", "tags": ["Sensor Data"], "responses": { "200": { "description": "Sensor data retrieved" } } },
      "post": { "summary": "Add a new sensor reading", "tags": ["Sensor Data"], "responses": { "201": { "description": "Sensor reading added" } } }
    },
    "/api/mongo/sensor-data/{id}": {
      "get": { "summary": "Get sensor data by ID", "tags": ["Sensor Data"], "responses": { "200": { "description": "Sensor data" }, "404": { "description": "Not found" } } },
      "put": { "summary": "Update sensor data", "tags": ["Sensor Data"], "responses": { "200": { "description": "Sensor data updated" } } },
      "patch": { "summary": "Patch sensor data", "tags": ["Sensor Data"], "responses": { "200": { "description": "Sensor data patched" } } },
      "delete": { "summary": "Delete sensor data", "tags": ["Sensor Data"], "responses": { "200": { "description": "Sensor data deleted" } } }
    },
    "/api/mongo/event-logs": {
      "get": { "summary": "Get event logs with filtering", "tags": ["Event Logs"], "responses": { "200": { "description": "Event logs retrieved" } } },
      "post": { "summary": "Create a new event log", "tags": ["Event Logs"], "responses": { "201": { "description": "Event log created" } } }
    },
    "/api/mongo/event-logs/{id}": {
      "get": { "summary": "Get event log by ID", "tags": ["Event Logs"], "responses": { "200": { "description": "Event log" }, "404": { "description": "Not found" } } },
      "put": { "summary": "Update event log", "tags": ["Event Logs"], "responses": { "200": { "description": "Event log updated" } } },
      "delete": { "summary": "Delete event log", "tags": ["Event Logs"], "responses": { "200": { "description": "Event log deleted" } } }
    },
    "/api/mongo/chat-messages": {
      "get": { "summary": "Get chat messages", "tags": ["Chat Messages"], "responses": { "200": { "description": "Chat messages retrieved" } } },
      "post": { "summary": "Send chat message", "tags": ["Chat Messages"], "responses": { "201": { "description": "Message sent" } } }
    },
    "/api/mongo/checklists": {
      "get": { "summary": "Get checklists", "tags": ["Checklists"], "responses": { "200": { "description": "Checklists retrieved" } } },
      "post": { "summary": "Create checklist", "tags": ["Checklists"], "responses": { "201": { "description": "Checklist created" } } }
    },
    "/api/mongo/checklists/{id}": {
      "get": { "summary": "Get checklist by ID", "tags": ["Checklists"], "responses": { "200": { "description": "Checklist" }, "404": { "description": "Not found" } } },
      "put": { "summary": "Update checklist", "tags": ["Checklists"], "responses": { "200": { "description": "Checklist updated" } } },
      "delete": { "summary": "Delete checklist", "tags": ["Checklists"], "responses": { "200": { "description": "Checklist deleted" } } }
    },
    "/api/analytics/kpi": {
      "get": {
        "summary": "Get KPIs",
        "tags": ["Analytics"],
        "parameters": [
          { "name": "startDate", "in": "query", "required": false, "description": "Start date for KPI calculation", "schema": { "type": "string", "format": "date" } },
          { "name": "endDate", "in": "query", "required": false, "description": "End date for KPI calculation", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": { "description": "KPIs retrieved" },
          "400": { "description": "Invalid date range" }
        }
      }
    },
    "/api/analytics/reports": {
      "get": { "summary": "Get reports", "tags": ["Analytics"], "responses": { "200": { "description": "Reports retrieved" } } }
    },
    "/api/predictive/alerts": {
      "get": {
        "summary": "Get predictive maintenance alerts",
        "tags": ["Predictive"],
        "parameters": [
          { "name": "assetId", "in": "query", "required": false, "description": "Filter alerts by asset ID", "schema": { "type": "string" } },
          { "name": "severity", "in": "query", "required": false, "description": "Filter alerts by severity", "schema": { "type": "string", "enum": ["low", "medium", "high", "critical"] } }
        ],
        "responses": {
          "200": { "description": "Alerts retrieved" },
          "404": { "description": "No alerts found" }
        }
      }
    },
    "/api/sensor-data/ingest": {
      "post": { "summary": "Ingest or simulate sensor data", "tags": ["Sensor Data"], "responses": { "201": { "description": "Sensor data ingested" } } }
    }
  }
}
