# Azure PostgreSQL
POSTGRES_HOST=<your-postgres-server>.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=prosynchub
POSTGRES_USER=<username>@<your-postgres-server>
POSTGRES_PASSWORD=<secure-password>

# Azure Cosmos DB
COSMOSDB_URI=https://<your-cosmos-account>.documents.azure.com:443/
COSMOSDB_KEY=<cosmos-primary-key>
COSMOSDB_DATABASE=prosynchub

# Azure Redis
REDIS_URL=rediss://:<password>@<your-redis-name>.redis.cache.windows.net:6380

# Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=<your-app-insights-key>

# (Optional) Azure Monitor Log Analytics
AZURE_LOG_ANALYTICS_WORKSPACE_ID=<your-workspace-id>
AZURE_LOG_ANALYTICS_SHARED_KEY=<your-shared-key>
